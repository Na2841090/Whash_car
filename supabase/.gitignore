# Criar .gitignore na raiz
@'
# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment
.env
.env.local
.env.*.local

# Supabase
supabase/.temp/
supabase/branches/

# Build
dist/
build/
*.tsbuildinfo

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
logs/

# Testing
coverage/
.nyc_output/

# Temporary
*.tmp
*.temp
'@ | Out-File -FilePath ".gitignore" -Encoding utf8