  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Na2841090/Whash_car/issues"
  },
  "homepage": "https://github.com/Na2841090/Whash_car#readme",
  "dependencies": {
    "@supabase/functions-js": "^2.107.0",
    "@supabase/supabase-js": "^2.107.0",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
